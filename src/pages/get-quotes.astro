---
import Base from '../layouts/Base.astro';
export const prerender = true;
---
<Base
  title="Get Free Car Rental Quotes — Dubai"
  description="Get 3 competing car rental quotes from verified Dubai companies in 2 hours. Free. No deposit. No spam."
>
<div class="bg-gradient-to-br from-navy to-brand py-12 px-4 text-white text-center">
  <h1 class="text-3xl font-black mb-2">Get Your Free Dubai Rental Quote</h1>
  <p class="text-blue-200">Tell us what you need. We send it to verified companies. They compete. You save.</p>
</div>

<div class="max-w-lg mx-auto px-4 py-10">
  <form id="quoteForm" class="bg-white rounded-2xl shadow-lg p-8 space-y-5">
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-3">What type of car?</label>
      <div class="grid grid-cols-2 gap-3">
        {[
          {id:"economy", label:"🚗 Economy", sub:"From AED 35/day"},
          {id:"suv", label:"🚙 SUV / 4x4", sub:"From AED 120/day"},
          {id:"luxury", label:"🏎️ Luxury", sub:"From AED 450/day"},
          {id:"van", label:"🚐 Van / Minibus", sub:"From AED 180/day"},
        ].map(c => (
          <label class="cursor-pointer">
            <input type="radio" name="carType" value={c.id} class="sr-only peer" required />
            <div class="border-2 border-gray-200 rounded-xl p-3 text-center peer-checked:border-brand peer-checked:bg-blue-50 transition-all">
              <div class="text-xl mb-1">{c.label.split(' ')[0]}</div>
              <div class="text-xs font-semibold text-gray-700">{c.label.split(' ').slice(1).join(' ')}</div>
              <div class="text-xs text-gray-400">{c.sub}</div>
            </div>
          </label>
        ))}
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Pick-up date</label>
        <input type="date" name="pickupDate" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Return date</label>
        <input type="date" name="returnDate" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand" />
      </div>
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Pickup location</label>
      <select name="pickupLocation" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand">
        <option value="" disabled selected>Select location</option>
        <option>Dubai International Airport (DXB)</option>
        <option>Al Maktoum Airport (DWC)</option>
        <option>Dubai Marina</option>
        <option>Downtown Dubai / Burj Khalifa</option>
        <option>JBR / JLT</option>
        <option>Business Bay</option>
        <option>Palm Jumeirah</option>
        <option>Deira / Dubai Creek</option>
        <option>Madinat Jumeirah</option>
        <option>DWTC / Trade Centre</option>
        <option>My hotel — I'll confirm address</option>
        <option>Other</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Your name</label>
      <input type="text" name="name" required placeholder="Ahmed Al Rashid" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand" />
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp / Phone</label>
      <div class="flex gap-2">
        <span class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500 whitespace-nowrap">🇦🇪 +971</span>
        <input type="tel" name="phone" required placeholder="50 123 4567" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand" />
      </div>
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Email (optional)</label>
      <input type="email" name="email" placeholder="you@example.com" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand" />
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Anything specific? (optional)</label>
      <textarea name="notes" rows="2" placeholder="No deposit, baby seat, monthly deal, family visit..." class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand resize-none"></textarea>
    </div>
    <button type="submit" id="submitBtn" class="w-full bg-brand text-white py-4 rounded-xl font-black text-lg hover:bg-navy transition-colors">
      Get My 3 Free Quotes →
    </button>
    <p class="text-center text-xs text-gray-400">No credit card. No obligation. We only share your details with verified Dubai rental companies.</p>
    <div class="flex justify-center gap-6 text-xs text-gray-400">
      <span>✓ Free to use</span>
      <span>✓ No spam calls</span>
      <span>✓ Verified companies only</span>
    </div>
  </form>

  <div id="successState" class="hidden bg-white rounded-2xl shadow-lg p-8 text-center">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">✓</div>
    <h2 class="text-xl font-black text-navy mb-2">Quote request sent!</h2>
    <p class="text-gray-500 mb-6">We are matching you with up to 3 verified Dubai rental companies right now.</p>
    <div class="bg-gray-50 rounded-xl p-4 text-left space-y-3">
      <div class="text-xs font-bold text-gray-400 uppercase tracking-wide">What happens next</div>
      <div class="flex gap-3 text-sm"><span class="w-5 h-5 rounded-full bg-teal text-white text-xs flex items-center justify-center flex-shrink-0 mt-0.5">1</span><span>A rental specialist calls or WhatsApps you within 2 hours</span></div>
      <div class="flex gap-3 text-sm"><span class="w-5 h-5 rounded-full bg-teal text-white text-xs flex items-center justify-center flex-shrink-0 mt-0.5">2</span><span>You receive up to 3 competing quotes — no obligation</span></div>
      <div class="flex gap-3 text-sm"><span class="w-5 h-5 rounded-full bg-teal text-white text-xs flex items-center justify-center flex-shrink-0 mt-0.5">3</span><span>You pick the best deal and book directly</span></div>
    </div>
  </div>
</div>

<script>
  const today = new Date().toISOString().split('T')[0];
  document.querySelector('input[name="pickupDate"]').min = today;
  document.querySelector('input[name="returnDate"]').min = today;

  document.getElementById('quoteForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.textContent = 'Sending...';
    btn.disabled = true;
    setTimeout(() => {
      document.getElementById('quoteForm').classList.add('hidden');
      document.getElementById('successState').classList.remove('hidden');
    }, 1500);
  });
</script>
</Base>
